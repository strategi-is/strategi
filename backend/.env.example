# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/strategi"

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=change_this_to_a_random_32_char_string

# ─── OLOSTEP ─────────────────────────────────────────────────────────────────
OLOSTEP_API_KEY=your_olostep_api_key_here
OLOSTEP_BASE_URL=https://agent.olostep.com/olostep-p2p-infer

# ─── LLM PROVIDERS ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
PERPLEXITY_API_KEY=your_perplexity_key_here

# ─── EMAIL (optional for dev) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@strategi.ai

# ─── ALERTS ──────────────────────────────────────────────────────────────────
ALERT_EMAIL=engineering@strategi.ai
OLOSTEP_COST_ALERT_THRESHOLD=300
